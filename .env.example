# DarkMax Bot Environment Variables
# Copy this file to .env and fill in your own values

# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter API Keys (comma-separated list)
OPENROUTER_KEYS=sk-or-v1-your_key_here,sk-or-v1-another_key_here

# Admin Key (optional, default will be generated if not set)
# If set, this key will be used as the admin key for authentication
ADMIN_KEY=your_admin_key_here

# Note: keys.json will be created automatically for storing user keys and sessions